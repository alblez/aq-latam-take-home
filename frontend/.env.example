# Browser-visible backend API URL.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Server-side backend API URL for Next.js server code.
API_URL=http://127.0.0.1:8000

# Local-only: use frontend mocks while backend work is in progress.
# Hosted demos must set this to false and use the deployed backend.
NEXT_PUBLIC_USE_MOCK=true
