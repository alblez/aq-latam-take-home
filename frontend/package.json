{
  "name": "ai-interviewer-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "24.x",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "contract-types": "openapi-typescript ../shared/contract.yaml -o types/api/contract.ts",
    "contract-types:check": "node scripts/check-contract-types.mjs",
    "quality": "pnpm contract-types:check && pnpm typecheck && pnpm lint && pnpm knip && pnpm test",
    "preflight": "pnpm quality && pnpm build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "next": "^16.2.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.17.1",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
