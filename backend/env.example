# PostgreSQL connection string used by FastAPI, SQLAlchemy, and Alembic.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/ai_interviewer

# OpenRouter credentials used by the backend for question generation and evaluation.
OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=

# Comma-separated frontend origins allowed to call the backend.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000
